{"remainingRequest":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\work\\codebuddy\\lietou\\frontend\\src\\views\\talent\\tag\\index.vue?vue&type=style&index=0&id=337effd4&lang=scss&scoped=true","dependencies":[{"path":"D:\\work\\codebuddy\\lietou\\frontend\\src\\views\\talent\\tag\\index.vue","mtime":1774321377900},{"path":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\css-loader\\dist\\cjs.js","mtime":1774322893339},{"path":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1774322893978},{"path":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\postcss-loader\\src\\index.js","mtime":1774322893579},{"path":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1774322893145},{"path":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1774322893145},{"path":"D:\\work\\codebuddy\\lietou\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1774322893807}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkKA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/talent/tag","sourcesContent":["<template>\r\n  <div class=\"tag-container\">\r\n    <div class=\"content-card\">\r\n      <div class=\"card-header\">\r\n        <h3>标签管理</h3>\r\n        <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">新增标签</el-button>\r\n      </div>\r\n\r\n      <el-table :data=\"tableData\" border stripe style=\"width: 100%\">\r\n        <el-table-column prop=\"name\" label=\"标签名称\" width=\"150\"></el-table-column>\r\n        <el-table-column prop=\"color\" label=\"颜色\" width=\"100\">\r\n          <template slot-scope=\"scope\">\r\n            <el-color-picker v-model=\"scope.row.color\" disabled size=\"mini\"></el-color-picker>\r\n            <span style=\"margin-left: 10px\">{{ scope.row.color }}</span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"category\" label=\"分类\" width=\"120\"></el-table-column>\r\n        <el-table-column prop=\"sort\" label=\"排序\" width=\"80\"></el-table-column>\r\n        <el-table-column prop=\"status\" label=\"状态\" width=\"80\">\r\n          <template slot-scope=\"scope\">\r\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\r\n              {{ scope.row.status === 1 ? '正常' : '禁用' }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"160\"></el-table-column>\r\n        <el-table-column label=\"操作\" fixed=\"right\" width=\"200\">\r\n          <template slot-scope=\"scope\">\r\n            <el-button size=\"mini\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n            <el-button size=\"mini\" type=\"danger\" @click=\"handleDelete(scope.row)\">删除</el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </div>\r\n\r\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"500px\" @close=\"handleDialogClose\">\r\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"80px\">\r\n        <el-form-item label=\"标签名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"颜色\">\r\n          <el-color-picker v-model=\"form.color\"></el-color-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"分类\">\r\n          <el-select v-model=\"form.category\" placeholder=\"请选择分类\" style=\"width: 100%\">\r\n            <el-option label=\"学历\" value=\"学历\"></el-option>\r\n            <el-option label=\"背景\" value=\"背景\"></el-option>\r\n            <el-option label=\"状态\" value=\"状态\"></el-option>\r\n            <el-option label=\"技术\" value=\"技术\"></el-option>\r\n            <el-option label=\"职位\" value=\"职位\"></el-option>\r\n            <el-option label=\"经验\" value=\"经验\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"排序\">\r\n          <el-input-number v-model=\"form.sort\" :min=\"0\" :max=\"999\"></el-input-number>\r\n        </el-form-item>\r\n        <el-form-item label=\"状态\">\r\n          <el-radio-group v-model=\"form.status\">\r\n            <el-radio :label=\"1\">正常</el-radio>\r\n            <el-radio :label=\"0\">禁用</el-radio>\r\n          </el-radio-group>\r\n        </el-form-item>\r\n      </el-form>\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"handleSubmit\">确 定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { getTagList, addTag, updateTag, deleteTag } from '@/api/tag'\r\n\r\nexport default {\r\n  name: 'Tag',\r\n  data() {\r\n    return {\r\n      tableData: [],\r\n      dialogVisible: false,\r\n      dialogTitle: '',\r\n      form: {\r\n        id: null,\r\n        name: '',\r\n        color: '#409EFF',\r\n        category: '',\r\n        sort: 0,\r\n        status: 1\r\n      },\r\n      rules: {\r\n        name: [{ required: true, message: '请输入标签名称', trigger: 'blur' }]\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadData()\r\n  },\r\n  methods: {\r\n    loadData() {\r\n      getTagList().then(response => {\r\n        if (response.data) {\r\n          this.tableData = response.data || []\r\n        }\r\n      })\r\n    },\r\n    handleAdd() {\r\n      this.dialogTitle = '新增标签'\r\n      this.form = {\r\n        id: null,\r\n        name: '',\r\n        color: '#409EFF',\r\n        category: '',\r\n        sort: 0,\r\n        status: 1\r\n      }\r\n      this.dialogVisible = true\r\n    },\r\n    handleEdit(row) {\r\n      this.dialogTitle = '编辑标签'\r\n      this.form = { ...row }\r\n      this.dialogVisible = true\r\n    },\r\n    handleDelete(row) {\r\n      this.$confirm('确认删除该标签吗？', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        deleteTag(row.id).then(response => {\r\n          if (response.success) {\r\n            this.$message.success('删除成功')\r\n            this.loadData()\r\n          } else {\r\n            this.$message.error(response.message || '删除失败')\r\n          }\r\n        })\r\n      })\r\n    },\r\n    handleSubmit() {\r\n      this.$refs.form.validate(valid => {\r\n        if (valid) {\r\n          const action = this.form.id ? updateTag : addTag\r\n          action(this.form).then(response => {\r\n            if (response.success) {\r\n              this.$message.success(this.form.id ? '更新成功' : '新增成功')\r\n              this.dialogVisible = false\r\n              this.loadData()\r\n            } else {\r\n              this.$message.error(response.message || '操作失败')\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    handleDialogClose() {\r\n      this.$refs.form.resetFields()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.tag-container {\r\n  .content-card {\r\n    margin-bottom: 20px;\r\n  }\r\n}\r\n</style>\r\n"]}]}